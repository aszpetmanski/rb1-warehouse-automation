<root main_tree_to_execute="MainTree">

  <BehaviorTree ID="MainTree">
    <RecoveryNode number_of_retries="2" name="FindCarryShelfRecovery">

      <Sequence name="FindCarryShelfMission">
        <InitShelfMission
          patrol_waypoints_input="4.447,4.206,-1.138; 4.761,3.545,-2.676; 2.790,1.067,-2.659; 1.520,0.409,-2.660; 0.408,2.580,0.370"
          dropoff_waypoint="4.39,4.02,1.08"
          init_waypoint="0.506,2.576,0.5"
          init_pose="{init_pose}"
          target_frame="map"
          patrol_waypoints="{patrol_waypoints}"
          dropoff_pose="{dropoff_pose}"
          candidate_center="{candidate_center}"
          candidate_left_leg="{candidate_left_leg}"
          candidate_right_leg="{candidate_right_leg}"
          shelf_center="{shelf_center}"
          shelf_left_leg="{shelf_left_leg}"
          shelf_right_leg="{shelf_right_leg}"
          predock_pose="{predock_pose}"
          dock_pose="{dock_pose}" />

        <RecoveryNode number_of_retries="50" name="AcquireValidatedShelfRecovery">
          <Sequence name="AcquireValidatedShelf">

            <PatrolUntilCandidate
              patrol_waypoints="{patrol_waypoints}"
              nav_action_name="navigate_to_pose"
              scan_topic="/scan"
              target_frame="map"
              left_window_start_idx="55"
              left_window_end_idx="305"
              right_window_start_idx="775"
              right_window_end_idx="1025"
              expected_leg_spacing="0.65"
              leg_spacing_tolerance="0.12"
              cluster_gap_tolerance="0.10"
              intensity_threshold="3500.0"
              max_detection_range="2.5"
              min_cluster_points="2"
              min_consecutive_hits="2"
              stable_hit_distance_tol="0.25"
              max_waypoint_failures="3"
              candidate_center="{candidate_center}"
              candidate_left_leg="{candidate_left_leg}"
              candidate_right_leg="{candidate_right_leg}"
              candidate_confidence="{candidate_confidence}"
              candidate_window="{candidate_window}" />

            <CustomDriveOnHeading
              distance="0.25"
              speed="0.05"
              time_allowance="9.0"
              cmd_vel_topic="/cmd_vel"
              odom_topic="/odom" />  

            <ValidateShelfCandidate
              scan_topic="/scan"
              cmd_vel_topic="/cmd_vel"
              target_frame="map"

              left_window_start_idx="40"
              left_window_end_idx="320"
              right_window_start_idx="760"
              right_window_end_idx="1040"

              expected_leg_spacing="0.65"
              leg_spacing_tolerance="0.09"
              cluster_gap_tolerance="0.06"
              intensity_threshold="4800.0"
              max_detection_range="2.5"
              min_cluster_points="5"
              min_consecutive_hits="3"
              stable_hit_distance_tol="0.18"
              stop_settle_time="0.40"
              wait_duration="10.0"
              max_scan_age="0.90"

              shelf_center="{shelf_center}"
              shelf_left_leg="{shelf_left_leg}"
              shelf_right_leg="{shelf_right_leg}"
              candidate_window="{candidate_window}" />

          </Sequence>

          <SequenceStar name="AcquireShelfRecoveryActions">
            <StopRobot />
            <ClearEntireCostmap service_name="local_costmap/clear_entirely_local_costmap"/>
            <Wait wait_duration="0.25"/>
          </SequenceStar>
        </RecoveryNode>

        <ComputePreDockPose
          shelf_left_leg="{shelf_left_leg}"
          shelf_right_leg="{shelf_right_leg}"
          target_frame="map"
          predock_offset="0.95"
          predock_pose="{predock_pose}" />

        <RecoveryNode number_of_retries="6" name="NavigateToPredockRecovery">
          <PipelineSequence name="NavigateToPredockWithReplanning">

            <RateController hz="1.0">
              <RecoveryNode number_of_retries="1" name="ComputePathToPredockRecovery">
                <ComputePathToPose goal="{predock_pose}" path="{path_to_predock}" planner_id="GridBased"/>
                <ClearEntireCostmap service_name="global_costmap/clear_entirely_global_costmap"/>
              </RecoveryNode>
            </RateController>

            <RecoveryNode number_of_retries="1" name="FollowPredockPathRecovery">
              <FollowPath path="{path_to_predock}" controller_id="FollowPath"/>
              <ClearEntireCostmap service_name="local_costmap/clear_entirely_local_costmap"/>
            </RecoveryNode>

          </PipelineSequence>

          <SequenceStar name="PredockRecoveryActions">
            <ClearEntireCostmap service_name="local_costmap/clear_entirely_local_costmap"/>
            <ClearEntireCostmap service_name="global_costmap/clear_entirely_global_costmap"/>
            <Spin spin_dist="1.57"/>
            <Wait wait_duration="5.0"/>
          </SequenceStar>
        </RecoveryNode>

        <RefineShelfGeometry
          scan_topic="/scan"
          cmd_vel_topic="/cmd_vel"
          target_frame="map"
          front_window_start_idx="400"
          front_window_end_idx="680"
          expected_leg_spacing="0.65"
          leg_spacing_tolerance="0.08"
          cluster_gap_tolerance="0.06"
          intensity_threshold="2700.0"
          max_detection_range="1.8"
          min_cluster_points="3"
          min_consecutive_hits="5"
          stable_hit_distance_tol="0.04"
          stop_settle_time="0.60"
          wait_duration="28.0"
          max_scan_age="0.40"
          side_window_size="45"
          side_range_cap="6.0"
          side_free_min_diff="0.15"
          shelf_center="{shelf_center}"
          shelf_left_leg="{shelf_left_leg}"
          shelf_right_leg="{shelf_right_leg}"
          shelf_normal_yaw="{shelf_normal_yaw}"
          shelf_tangent_yaw="{shelf_tangent_yaw}"
          backup_turn_sign="{backup_turn_sign}"
          left_free_score="{left_free_score}"
          right_free_score="{right_free_score}" />

        <ComputePreDockPose
          shelf_left_leg="{shelf_left_leg}"
          shelf_right_leg="{shelf_right_leg}"
          target_frame="map"
          predock_offset="0.45"
          predock_pose="{predock_pose_refined}" />

        <AdjustToPoseLocal
          goal="{predock_pose_refined}"
          target_frame="map"
          cmd_vel_topic="/cmd_vel"
          robot_base_frame="robot_base_footprint"
          xy_tolerance="0.05"
          yaw_tolerance="0.05"
          max_linear_speed="0.05"
          max_angular_speed="0.25"
          control_rate="10.0" />    

        <DockToShelf
          shelf_center="{shelf_center}"
          shelf_normal_yaw="{shelf_normal_yaw}"
          target_frame="map"
          cmd_vel_topic="/cmd_vel"
          elevator_up_topic="/elevator_up"
          robot_base_frame="robot_base_link"
          drive_distance="0.70"
          forward_speed="0.07"
          yaw_gain="1.9"
          max_angular_speed="0.45"
          control_rate="10.0" />

        <SwitchToCarryMode
          carry_footprint="[[0.53,0.45],[0.53,-0.45],[-0.33,-0.45],[-0.33,0.45]]"
          footprint_padding="0.01"
          local_inflation_radius="0.52"
          local_cost_scaling_factor="4.0"
          global_inflation_radius="0.52"
          global_cost_scaling_factor="7.0" />
        
        <CustomBackUp
          distance="1.25"
          speed="0.10"
          time_allowance="25.0"
          turn_sign="{backup_turn_sign}"
          turn_angular_speed="0.05"
          cmd_vel_topic="/cmd_vel"
          odom_topic="/odom" />

        <RecoveryNode number_of_retries="6" name="NavigateToDropoffRecovery">
          <PipelineSequence name="NavigateToDropoffWithReplanning">

            <RateController hz="1.0">
              <RecoveryNode number_of_retries="1" name="ComputePathToDropoffRecovery">
                <ComputePathToPose goal="{dropoff_pose}" path="{path_to_dropoff}" planner_id="GridBased"/>
                <ClearEntireCostmap service_name="global_costmap/clear_entirely_global_costmap"/>
              </RecoveryNode>
            </RateController>

            <RecoveryNode number_of_retries="1" name="FollowDropoffPathRecovery">
              <FollowPath path="{path_to_dropoff}" controller_id="FollowPath"/>
              <ClearEntireCostmap service_name="local_costmap/clear_entirely_local_costmap"/>
            </RecoveryNode>

          </PipelineSequence>

          <SequenceStar name="DropoffRecoveryActions">
            <ClearEntireCostmap service_name="local_costmap/clear_entirely_local_costmap"/>
            <ClearEntireCostmap service_name="global_costmap/clear_entirely_global_costmap"/>
            <CustomBackUp
                distance="0.10"
                speed="0.05"
                time_allowance="15.0"
                cmd_vel_topic="/cmd_vel"
                odom_topic="/odom" />
            <Spin spin_dist="1.57"/>
            <Wait wait_duration="5.0"/>
          </SequenceStar>
        </RecoveryNode>

        <PlaceShelf
          dropoff_pose="{dropoff_pose}"
          target_frame="map"
          drive_distance="0.95"
          forward_speed="0.10"
          yaw_gain="2.0"
          max_angular_speed="0.35"
          yaw_tolerance="0.03"
          control_rate="20.0"
          align_timeout="18.0"
          motion_timeout="22.0"
          stop_settle_time="0.30"
          elevator_trigger_count="4"
          elevator_trigger_interval="0.15"
          cmd_vel_topic="/cmd_vel"
          elevator_down_topic="/elevator_down" />

        <SwitchToNormalMode
          normal_robot_radius="0.27"
          footprint_padding="0.01"
          local_inflation_radius="0.29"
          local_cost_scaling_factor="2.0"
          global_inflation_radius="0.29"
          global_cost_scaling_factor="2.0"
          local_footprint_clearing_enabled="true"
          global_footprint_clearing_enabled="true"
          clear_costmaps="true"
          post_param_wait_sec="0.20"
          post_clear_wait_sec="0.20"
          local_costmap_node="/local_costmap/local_costmap"
          global_costmap_node="/global_costmap/global_costmap"
          local_clear_service="/local_costmap/clear_entirely_local_costmap"
          global_clear_service="/global_costmap/clear_entirely_global_costmap"
          local_inflation_layer_name="inflation_layer"
          global_inflation_layer_name="inflation_layer"
          local_clearing_layer_name="obstacle_layer"
          global_clearing_layer_name="obstacle_layer" />

        <CustomBackUp
          distance="1.10"
          speed="0.10"
          time_allowance="25.0"
          cmd_vel_topic="/cmd_vel"
          odom_topic="/odom" />

        <RecoveryNode number_of_retries="6" name="NavigateToInitRecovery">
            <PipelineSequence name="NavigateToInitWithReplanning">

                <RateController hz="1.0">
                <RecoveryNode number_of_retries="1" name="ComputePathToInitRecovery">
                    <ComputePathToPose goal="{init_pose}" path="{path_to_init}" planner_id="GridBased"/>
                    <ClearEntireCostmap service_name="global_costmap/clear_entirely_global_costmap"/>
                </RecoveryNode>
                </RateController>

                <RecoveryNode number_of_retries="1" name="FollowInitPathRecovery">
                <FollowPath path="{path_to_init}" controller_id="FollowPath"/>
                <ClearEntireCostmap service_name="local_costmap/clear_entirely_local_costmap"/>
                </RecoveryNode>

            </PipelineSequence>

            <SequenceStar name="InitRecoveryActions">
                <ClearEntireCostmap service_name="local_costmap/clear_entirely_local_costmap"/>
                <ClearEntireCostmap service_name="global_costmap/clear_entirely_global_costmap"/>
                <Spin spin_dist="1.57"/>
                <Wait wait_duration="5.0"/>
            </SequenceStar>
        </RecoveryNode>      

      </Sequence>

      <SequenceStar name="MissionRecoveryActions">
        <StopRobot />
        <ClearEntireCostmap service_name="local_costmap/clear_entirely_local_costmap"/>
        <ClearEntireCostmap service_name="global_costmap/clear_entirely_global_costmap"/>
        <Spin spin_dist="1.57"/>
        <Wait wait_duration="3.0"/>
      </SequenceStar>

    </RecoveryNode>
  </BehaviorTree>

</root>

