<root main_tree_to_execute="MainTree">

  <BehaviorTree ID="MainTree">
    <RecoveryNode number_of_retries="2" name="FindCarryShelfRecovery">

      <Sequence name="FindCarryShelfMission">

        <InitShelfMission
          patrol_waypoints_input="0,0.45,1.57; 1.5,0.45,0; 2.8,0.45,0; 3.4,0.4,0; 3.4,0,0; 5.7,0,0; 5.7,0,-3.14; 4.3,-0.4,-3.14; 3.25,-0.4,-3.14; 2.20,-0.4,-3.14; 0.6,-0.4,-3.14; 0.6,-3.0,1.55; 0.5,0,-3.14; 0,0,0"
          dropoff_waypoint="0.0,0.0,0.00"
          target_frame="map"
          patrol_waypoints="{patrol_waypoints}"
          dropoff_pose="{dropoff_pose}"
          candidate_center="{candidate_center}"
          candidate_left_leg="{candidate_left_leg}"
          candidate_right_leg="{candidate_right_leg}"
          shelf_center="{shelf_center}"
          shelf_left_leg="{shelf_left_leg}"
          shelf_right_leg="{shelf_right_leg}"
          predock_pose="{predock_pose}"
          dock_pose="{dock_pose}" />

        <PatrolUntilCandidate
          patrol_waypoints="{patrol_waypoints}"
          nav_action_name="navigate_to_pose"
          scan_topic="/scan"
          target_frame="map"
          left_window_start_idx="65"
          left_window_end_idx="295"
          right_window_start_idx="785"
          right_window_end_idx="1015"
          expected_leg_spacing="0.60"
          leg_spacing_tolerance="0.08"
          cluster_gap_tolerance="0.10"
          intensity_threshold="7500.0"
          max_detection_range="2.5"
          min_cluster_points="2"
          min_consecutive_hits="3"
          stable_hit_distance_tol="0.20"
          max_waypoint_failures="3"
          candidate_center="{candidate_center}"
          candidate_left_leg="{candidate_left_leg}"
          candidate_right_leg="{candidate_right_leg}"
          candidate_confidence="{candidate_confidence}" />

        <ValidateShelfCandidate
          candidate_center="{candidate_center}"
          candidate_left_leg="{candidate_left_leg}"
          candidate_right_leg="{candidate_right_leg}"
          shelf_center="{shelf_center}"
          shelf_left_leg="{shelf_left_leg}"
          shelf_right_leg="{shelf_right_leg}"
          wait_duration="5.0" />

        <ComputePreDockPose
          shelf_center="{shelf_center}"
          target_frame="map"
          predock_pose="{predock_pose}"
          dock_pose="{dock_pose}" />

        <SubTree ID="NavigateRobustly" goal="{predock_pose}" path="{path}" />

        <DockToShelf wait_duration="5.0" />

        <LiftShelf />

        <SubTree ID="NavigateRobustly" goal="{dropoff_pose}" path="{path}" />

        <PlaceShelf />

      </Sequence>

      <SequenceStar name="MissionRecoveryActions">
        <StopRobot />
        <ClearEntireCostmap service_name="local_costmap/clear_entirely_local_costmap"/>
        <ClearEntireCostmap service_name="global_costmap/clear_entirely_global_costmap"/>
        <Spin spin_dist="1.57"/>
        <Wait wait_duration="3"/>
      </SequenceStar>

    </RecoveryNode>
  </BehaviorTree>

  <BehaviorTree ID="NavigateRobustly">
    <RecoveryNode number_of_retries="6" name="NavigateRecovery">
      <PipelineSequence name="NavigateWithReplanning">
        <RateController hz="1.0">
          <RecoveryNode number_of_retries="1" name="ComputePathToPose">
            <ComputePathToPose goal="{goal}" path="{path}" planner_id="GridBased"/>
            <ClearEntireCostmap service_name="global_costmap/clear_entirely_global_costmap"/>
          </RecoveryNode>
        </RateController>

        <RecoveryNode number_of_retries="1" name="FollowPath">
          <FollowPath path="{path}" controller_id="FollowPath"/>
          <ClearEntireCostmap service_name="local_costmap/clear_entirely_local_costmap"/>
        </RecoveryNode>
      </PipelineSequence>

      <SequenceStar name="RecoveryActions">
        <ClearEntireCostmap service_name="local_costmap/clear_entirely_local_costmap"/>
        <ClearEntireCostmap service_name="global_costmap/clear_entirely_global_costmap"/>
        <Spin spin_dist="1.57"/>
        <Wait wait_duration="5"/>
      </SequenceStar>
    </RecoveryNode>
  </BehaviorTree>

</root>